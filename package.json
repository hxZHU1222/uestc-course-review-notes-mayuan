{
  "name": "uestc-course-review-notes-mayuan",
  "version": "1.0.0",
  "private": true,
  "description": "Static review app packaged as Android and Windows desktop releases.",
  "author": "hxZHU1222",
  "main": "electron/main.cjs",
  "scripts": {
    "build:windows": "electron-builder --win --publish never",
    "cap:sync:android": "cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "electron": "^31.7.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.hxzhu1222.mayuan",
    "productName": "Mayuan Review",
    "directories": {
      "output": "build-out"
    },
    "files": [
      "index.html",
      "css/**/*",
      "js/**/*",
      "data/**/*",
      "assets/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
